# Environment Configuration Template
# Copy this to .env.local (development) or set these in your hosting provider

# Node Environment
NODE_ENV=development

# API Configuration
VITE_API_URL=http://localhost:3000

# Email Configuration (SendGrid - Optional)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@technocrat-horizons.com

# Google Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=your_ga_tracking_id

# Sentry (Error Tracking - Optional)
SENTRY_DSN=your_sentry_dsn_url# Redis Cache (Optional)
REDIS_URL=redis://localhost:6379

# AWS Configuration (if using S3 for uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name

# Stripe (if using payments)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Application Configuration
APP_NAME=Alpha Grid
APP_URL=https://alpha-grid.com
APP_DEBUG=false

# Features (true/false)
ENABLE_NEWSLETTER=true
ENABLE_CONTACT_FORM=true
ENABLE_BLOG_COMMENTS=false
ENABLE_ANALYTICS=true
